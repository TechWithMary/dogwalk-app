# HappiWalk - Environment Variables Example
# Copy this file to .env and fill in your real values
# .env is in .gitignore and should NEVER be committed

# ==========================================
# SUPABASE (REQUIRED)
# ==========================================
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ==========================================
# GOOGLE MAPS (REQUIRED for maps and address search)
# ==========================================
# Get from: https://console.cloud.google.com/apis/credentials
# Restrict by package: com.happiwalk.app, com.happiwalk.app (iOS + Android)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=AIza...

# ==========================================
# MERCADO PAGO (REQUIRED for payments)
# ==========================================
# Get from: https://www.mercadopago.com.co/developers/panel
EXPO_PUBLIC_MERCADOPAGO_PUBLIC_KEY=APP_USR-...

# ==========================================
# EAS SECRETS (set with `eas secret:create`, NOT in .env)
# ==========================================
# These are configured via EAS, not via .env file:
# - MERCADOPAGO_ACCESS_TOKEN (server-side only, in Supabase Edge Function secrets)
# - APNS_KEY_ID, APNS_KEY_P8 (configured via `eas credentials`)
# - FCM_SERVICE_ACCOUNT_KEY (configured via `eas credentials`)
